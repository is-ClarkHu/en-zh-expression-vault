# --- Captured corpus (personal + copyrighted; NEVER commit) ---
# Real chat logs, lookups, and Q&A exchanges stay on-device only (SPEC §7, §10).
raw_capture/
*.vault.json
*.vault.sqlite
*-vault-export-*.json
vault-*.json
docs/vault-*.json

# --- Generated / derived data (regenerable; not a runtime dependency) ---
# Only the small public demo vault under data/sample/ is committed.
data/*
!data/sample
!data/sample/**

# Embedding cache and pronunciation audio caches (regenerable, large) — SPEC §8.
# Root-anchored so they don't shadow source dirs like src/audio/.
/embeddings/
/audio/

# --- Secrets ---
.env
.env.*
!.env.example

# --- Python (self-contained venv for tools/recluster.py) ---
venv/
.venv/
__pycache__/
*.pyc

# --- Node / build output ---
node_modules/
dist/
dist-standalone/
dist-electron/
release/

# --- Design docs (kept local, not published) — SPEC §10 ---
# All SPEC-* iteration docs stay out of the public repo (v1, v2, …).
docs/SPEC-*.md
SPEC-*.md

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
