# Copy to ".env" (gitignored) and fill in what you use.

# --- LLM keys: BATCH TOOL ONLY (tools/recluster.py, SPEC §5) ---
# The web app does NOT read these — its "ask / explain" key is entered in the
# app's Settings and stays on-device, so secrets never end up in a build.
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Dropbox app key: read by the WEB APP as a fallback ---
# NOT a secret in the PKCE public-client flow, so it's safe to read/bundle. Set
# it here to connect sync without pasting the key in Settings each install.
# Create an app at https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=
