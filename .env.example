# Copy to ".env" (gitignored) and fill in the key for the provider you use.
#
# This is the BATCH-TIME key for tools/recluster.py (periodic tag reclustering
# + edge refresh, SPEC §5). It is separate from the in-app "ask / explain" key,
# which you enter in the app's Settings — real chat logs never leave the device.

# recluster.py --provider deepseek   (DEFAULT — cheap & fast for big runs)
DEEPSEEK_API_KEY=

# recluster.py --provider anthropic
ANTHROPIC_API_KEY=

# recluster.py --provider openai
OPENAI_API_KEY=
